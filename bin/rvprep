#!/usr/bin/env bash
set -euo pipefail

: "${YT_URL:?YT_URL not set}"
: "${YTMUSIC_URL:?YTMUSIC_URL not set}"

VENDOR="$HOME/los/vendor/revanced"
if [ ! -d "$VENDOR" ]; then
    echo "error: $VENDOR does not exist — clone vendor/revanced first" >&2
    exit 1
fi

TMP=$(mktemp -d)
trap 'rm -rf "$TMP"' EXIT

place() {
    local zip_url="$1" main_name="$2" app_dest="$3" patched_dest="$4"
    local work="$TMP/$(basename "$app_dest" .apk)"
    mkdir -p "$work"

    echo "[*] fetching $zip_url"
    curl -fsSL "$zip_url" -o "$work.zip"
    unzip -q "$work.zip" -d "$work"

    local main_apk base_apk
    main_apk=$(find "$work" -name "$main_name" -print -quit)
    base_apk=$(find "$work" -name 'base.apk'  -print -quit)

    if [ -z "$main_apk" ] || [ -z "$base_apk" ]; then
        echo "error: could not locate $main_name or base.apk in $zip_url" >&2
        exit 1
    fi

    install -D -m 644 "$main_apk" "$VENDOR/$app_dest"
    install -D -m 644 "$base_apk" "$VENDOR/$patched_dest"
    echo "[+] placed $app_dest and $patched_dest"
}

place "$YT_URL" \
      "com.google.android.apps.youtube.apk" \
      "common/product/app/YouTube/YouTube.apk" \
      "common/product/etc/rv/YouTube_patched.apk"

place "$YTMUSIC_URL" \
      "com.google.android.apps.youtube.music.apk" \
      "common/product/app/YTMusic/YTMusic.apk" \
      "common/product/etc/rv/YTMusic_patched.apk"

echo "[*] running extract-libs.sh"
( cd "$VENDOR" && bash extract-libs.sh )

echo "[done] revanced prebuilts processed"
